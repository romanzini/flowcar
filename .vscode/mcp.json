{
    "inputs": [
        {
            "id": "github_token",
            "type": "promptString",
            "description": "GitHub Personal Access Token (com permissões: repo, issues, pull_requests)",
            "password": true
        },
        {
            "id": "CONTEXT7_API_KEY",
            "type": "promptString",
            "description": "your Context7 API key",
            "password": true
        }
    ],
    "servers": {
        "github-mcp-server": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "ghcr.io/github/github-mcp-server"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
            }
        },
        "io.github.upstash/context7": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "@upstash/context7-mcp@1.0.31"
            ],
            "env": {
                "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
            },
            "gallery": "https://api.mcp.github.com",
            "version": "1.0.31"
        }
    }
}
